// ---------- Препроцессор ----------
// #определить VERSION 2
// #включить "std.kcore"
// #если (VERSION == 1)
//     целое V = 1;
// #иначе если (VERSION == 2)
//     целое V = 2;
// #иначе
//     целое V = 0;
// #конец
// #еслиопределено(DEBUG)
//     // ничего
// #конец
// #ошибка "Это сообщение не появится при парсинге"
// #указание once

// ---------- Структуры ----------
структура Битовые {
    байт f1 : 1;
    байт f2 : 2;
    целое f3 : 4;
};

структура Точка {
    целое x;
    целое y;
};

структура Прямоугольник {
    Точка лево_верх;
    Точка право_низ;
    целое[3] цвета;
};

// ---------- Глобальные переменные ----------
целое глобал_1 = 100 + 100 * 54 ^ 3;
байт глобал_2;
Точка* глобал_3 = ничто;
ничто глобал_4;

// ---------- Функции ----------
целое факториал(целое n) {

    /* - Встроенный ассемблер пока не сделан.
        .eax = 5;
        .eax += переменная_1;
    */

    если (n <= 1) {
        вернуть 1;
    }
    вернуть n * факториал(n - 1);
}

// Ссылка в параметре
ничто обмен(целое& a, целое& b) {
    целое t = a;
    a = b;
    b = t;
}

// Указатель и динамическое выделение (условно)
целое* создать_целое(целое значение) {
    целое* ptr = ничто;
    // тут был бы malloc, но для примера просто вернём ничто
    вернуть ptr;
}

// Функция с массивом
целое сумма_массива(целое[] arr, целое нашразмер) {
    целое s = 0;
    для (целое i = 0; i < размер; i = i + 1) {
        s = s + arr[i];
    }
    вернуть s;
}

// Функция с параметром-массивом через указатель
целое сумма_указатель(целое* arr, целое нашразмер) {
    целое s = 0;
    для (целое i = 0; i < размер; i = i + 1) {
        s = s + arr[i];
    }
    вернуть s;
}

// ---------- Точка входа ----------
целое главная(целое argc, байт*[] argv) {
    // ---- Декларации переменных ----
    целое a = 10, b = 20, c;
    логическое flag = истина;
    байт bt = 255;
    короткое sh = -1000;
    длинное lg = 123456789012345;
    дробное fl = 3.14159f;
    десятичное db = 2.718281828459045;
    битфлаговый bf = 0b10101010;
    беззнаковый целое uuuu = 4000000000;

    // ---- Массивы ----
    целое[] статический = [1, 2, 3];
    целое динамический[10];
    целое[][] матрица[5][5];

    // ---- Структуры ----
    Точка p;
    p.x = 30;
    p.y = 40;
    Прямоугольник rect;
    rect.лево_верх = p;

    // ---- Указатели и ссылки ----
    целое* ptr = &a;
    *ptr = 100;
    целое& ref = a;
    ref = 200;

    // ---- Арифметические выражения (все операторы) ----
    c = a + b - 5 * 2;
    c = a / b;          // вещественное деление
    c = a \ b;          // целочисленное деление
    c = a % b;
    c = a ** 3;         // возведение в степень
    c = a << 2;
    c = a >> 1;
    c = a <<< 1;        // вращение влево
    c = a >>> 1;        // вращение вправо
    flag = a < b и (c > 10 или не flag);
    flag = (a == b) != flag;
    c = (a > b) ? a : b;

    // ---- Составные присваивания ----
    a += 5;
    b -= 3;
    c *= 2;
    c /= 2;
    c \= 3;
    c %= 4;
    c **= 2;
    a &= 0xFF;
    b |= 0x0F;
    c ^= 0xAA;
    a <<= 2;
    b >>= 1;
    c <<<= 1;
    c >>>= 1;

    // ---- Условный оператор ----
    если (a > 100) {
        a = 100;
    } иначе если (a < 0) {
        a = 0;
    } иначе если (a == 50) {
        a = 50;
    } иначе {
        a = a + 1;
    }

    // ---- Цикл while ----
    пока (a > 0) {
        a = a - 1;
        если (a == 5) {
            выход;      // break
        }
        если (a == 10) {
            продолжить; // continue
        }
    }

    // ---- Цикл do-while ----
    сначала {
        b = b - 1;
    } потом_если (b > 0);

    // ---- Цикл for ----
    для (целое i = 0; i < 10; i = i + 1) {
        если (i == 3) продолжить;
        если (i == 7) выход;
    }

    // ---- foreach (перебрать) ----
    целое[] числа = [1, 2, 3, 4, 5];
    целое сумма = 0;
    перебрать (целое x из числа) {
        сумма = сумма + x;
    }

    // ---- Выбор (switch) ----
    выбор (сумма) {
        метка 15 {
            сумма = 100;
            выход;
        }
        метка 20, метка 25 {
            сумма = 200;
        }
        метка 30 {
            сумма = 300;
        }
        по_умолчанию {
            сумма = 0;
        }
    }

    // ---- Goto и метка ----
    перейти метка_привет;
    a = -1;
    метка_привет:
    a = 0;

    // ---- Прямой ассемблерный код (без блока) ----
    // Это обычные выражения KCore: . регистр, <<<= и т.д.
    .eax = 0x80000000;
    .eax <<<= 1;
    .ebx = .eax >>> 1;
    // Использование переменных внутри прямого ассемблера
    .ecx = a;
    .ecx += b;

    // ---- Блочная ассемблерная вставка (сырой текст) ----
    ассемблер {
        mov eax, 42
        add eax, ebx
        ret
    }

    // ---- Вызов функций ----
    целое f = факториал(6);                // 720
    обмен(a, b);
    целое s1 = сумма_массива(числа, 5);
    целое s2 = сумма_указатель(&a, 1);
    целое* pnum = создать_целое(100);

    // ---- Вернуть результат ----
    вернуть 0;

    // Недостижимый код, но синтаксис проверяется
}
